# BigQuery Production Configuration
# Copy this file to .env.bigquery and update with your values

# Database Backend
DATABASE_BACKEND=bigquery

# BigQuery Settings
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=raw
BIGQUERY_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Storage Backend
STORAGE_BACKEND=gcs

# GCS Settings
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=github-archive-raw-data-prod

# Airflow Settings
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false

# dbt Settings
DBT_PROFILES_DIR=.
DBT_TARGET=bigquery

# Batch Processing
DATABASE_BATCH_SIZE=5000
DOWNLOAD_OUTPUT_DIR=/tmp/github-archive

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

