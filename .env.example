# Local Development Environment Configuration
# Copy this to .env and adjust as needed

# Pipeline Mode
PIPELINE_MODE=local

# GitHub Archive Client
GITHUB_ARCHIVE_CONNECT_TIMEOUT=5.0
GITHUB_ARCHIVE_READ_TIMEOUT=30.0
GITHUB_ARCHIVE_MAX_RETRIES=3

# Storage Backend (minio or gcs)
STORAGE_BACKEND=minio

# MinIO Configuration (Local)
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=github-archive
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Database Backend (postgresql or bigquery)
DATABASE_BACKEND=postgresql

# PostgreSQL Configuration (Local)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=github_archive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public

# Download Configuration
DOWNLOAD_CHUNK_SIZE=1048576
DOWNLOAD_MAX_WORKERS=3
DOWNLOAD_OUTPUT_DIR=./data

# Logging Configuration
LOG_LEVEL=INFO
LOG_JSON=false

